# Slack secrets and channel IDs
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me
LUNCH_CHANNEL_ID=C0123456789
OPS_CHANNEL_ID=C0123456789
BAPRATUSTRA_LEADERBOARD_URL=http://internal-host:8030/
BAPRATUSTRA_CANDIDATE_URL=http://internal-host:8031/suggest

# Google Sheet and the local service-account credential file
GOOGLE_SPREADSHEET_ID=replace-me
GOOGLE_SERVICE_ACCOUNT_FILE=/etc/bapratustra/google-service-account.json

# Keep this explicit in production even though this is the default.
BAPRATUSTRA_TIMEZONE=Asia/Seoul
